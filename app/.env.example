# Local Supabase config
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OAuth providers like Google and Discord are enabled in the Supabase dashboard.
# Add these app URLs to Supabase Auth redirect allow list:
#   http://localhost:3000/auth/callback
#   https://feh-barracks-manager.vercel.app/auth/callback
# In Google/Discord provider dashboards, register the Supabase callback URL shown in
# Supabase Authentication -> Providers (typically https://<project-ref>.supabase.co/auth/v1/callback).

# Optional override for local data path
# DB_ROOT=
